<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvHeaderCoordinator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="QUẢN LÝ ĐƠN HÀNG CHI NHÁNH"
        android:textStyle="bold"
        android:background="@android:color/white"
        android:elevation="4dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCoordinatorOrders"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/tvHeaderCoordinator"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/tvCoordinatorOrderEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Không có đơn hàng nào."
        android:visibility="gone"/>
</RelativeLayout>