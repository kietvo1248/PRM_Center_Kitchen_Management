<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="#F5F5F5">

    <androidx.appcompat.widget.SearchView android:id="@+id/searchView" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="12dp" android:background="@android:color/white" android:queryHint="Tìm tên cửa hàng..."/>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rvStores" android:layout_width="match_parent" android:layout_height="match_parent" android:layout_below="@id/searchView" android:paddingBottom="80dp" android:clipToPadding="false"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton android:id="@+id/fabAddStore" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentBottom="true" android:layout_alignParentEnd="true" android:layout_margin="16dp" android:src="@android:drawable/ic_input_add" android:backgroundTint="#1976D2" android:tint="#FFFFFF"/>
</RelativeLayout>