# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files (Tương đương node_modules + cache)
.gradle/
build/

# Local configuration file (SDK location settings)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ IDEA / Android Studio (Cấu hình IDE)
.idea/
*.iml
*.ipr
*.iws
*.name

# Keystore files (Nên bỏ qua để tránh lộ key upload app)
*.jks
*.keystore

# Google Services (File cấu hình Firebase - Tùy dự án có share hay không, thường là không nên public)
# google-services.json

# OS specific (File rác của hệ điều hành)
.DS_Store
Thumbs.db